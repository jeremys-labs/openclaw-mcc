# Core settings
CONTENT_ROOT=~/.openclaw
GATEWAY_PORT=18789
GATEWAY_TOKEN=your-token-here
SERVER_PORT=8081
CLIENT_PORT=3001

# Voice services (all optional)
WHISPER_SERVER_URL=http://127.0.0.1:8090/inference   # Whisper HTTP server for STT
WHISPER_CLI=/usr/local/bin/whisper                     # Whisper CLI binary path
FFMPEG_BIN=/usr/local/bin/ffmpeg                       # FFmpeg binary for audio conversion
KOKORO_URL=http://127.0.0.1:8880                       # Kokoro TTS server URL
